#!/usr/bin/env bash

error() {
  echo "Error: $*"
  exit 1
}

which docker &>/dev/null || error "docker isn't installed"
which realpath &>/dev/null || error "realpath isn't installed. Install coreutils with homebrew."
cd "$(dirname "$BASH_SOURCE")" || error "Failed to find auto-pi-gen's dir"

cp config pi-gen/config || error "Failed to copy config file to pi-gen"

# The Dockerfile does `COPY . /pi-gen/`, so a stage outside pi-gen/ would not
# exist inside the build container. STAGE_LIST in ./config points at mystage.
rm -rf pi-gen/mystage || error "Failed to clear stale mystage"
cp -r mystage pi-gen/mystage || error "Failed to copy mystage to pi-gen"

cd pi-gen || error "Failed to find pi-gen's dir"
./build-docker.sh || error "Failed to build on ./config"
